# ─── MongoDB ─────────────────────────────────────────────────────────────────
# Your MongoDB connection string (Atlas free tier works)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/flinkfreight

# ─── Resend (email) ──────────────────────────────────────────────────────────
# 1. Sign up free at https://resend.com
# 2. Create an API key under Settings → API Keys
# 3. Paste it here
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Address Resend sends FROM.
# • During development you can use the Resend sandbox: onboarding@resend.dev
#   (emails will only be delivered to the address you signed up with)
# • In production: verify your domain in Resend and use your own address,
#   e.g. noreply@flinkfreight.com
RESEND_FROM_EMAIL=onboarding@resend.dev

# The inbox that receives the contact-form notifications (your team's email)
CONTACT_TO_EMAIL=info@flinkfreight.com
